# Frontend environment
# Leave VITE_API_URL empty in local development to use Vite proxy (/api -> backend)
# Set it in production builds if frontend and backend are on different domains.
VITE_API_URL=

# Used by Vite dev server proxy target
VITE_BACKEND_URL=http://localhost:5000

# Google OAuth Client ID (get from Google Cloud Console)
# Steps to get this:
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project
# 3. Enable Google+ API
# 4. Go to Credentials and create OAuth 2.0 Client ID
# 5. Add authorized JavaScript origins:
#    - http://localhost:3000
#    - http://localhost:5173
# 6. Copy the Client ID here
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE

# Google Maps API Key (for location search and map display)
# Steps to get this:
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project (if not already created)
# 3. Enable these APIs:
#    - Maps JavaScript API
#    - Places API
#    - Maps Embed API
# 4. Go to Credentials and create an API Key
# 5. Restrict the API key to:
#    - Application restrictions: HTTP referrers (websites)
#    - Add: http://localhost:*
#    - Add: https://yourdomain.com (for production)
# 6. API restrictions: Select the APIs mentioned above
# 7. Copy the API Key here
VITE_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

